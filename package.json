{
  "name": "strava-food-backend",
  "version": "1.0.0",
  "description": "Backend Express TS pour Dashboard Strava et OpenFoodFacts",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
